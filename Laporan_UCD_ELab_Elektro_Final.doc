\trowd\trgaph80\trleft0 \clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx400\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx2000\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx4900\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx5800\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx8900
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 H1\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Visibility of System Status\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 User bingung saat memproses peminjaman karena layar terasa "hang". Status loading tersembunyi pada saat pengajuan dikirimkan ke server.\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 3 \u8212? Major\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Menambahkan indikator loading spinner yang menutupi layar saat pengajuan dilakukan, dilengkapi progress bar pada alur keranjang peminjaman.\cell
\row
\trowd\trgaph80\trleft0 \clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx400\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx2000\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx4900\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx5800\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx8900
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 H2\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Match Between System & Real World\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Sistem awalnya menggunakan istilah teknis database seperti id_alat dan user_role yang membingungkan mahasiswa awam.\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 2 \u8212? Minor\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Mengganti seluruh istilah teknis dengan bahasa sehari-hari di kampus: "Nama Alat", "NPM", "Penjaga Lab", "Denda Telat".\cell
\row
\trowd\trgaph80\trleft0 \clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx400\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx2000\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx4900\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx5800\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx8900
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 H3\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 User Control and Freedom\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Pengguna tidak sengaja menambah alat ke keranjang namun tidak ada opsi untuk membatalkan atau menghapus sebelum pengajuan dikirim.\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 3 \u8212? Major\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Menyediakan tombol "Hapus" (ikon tong sampah) di setiap item keranjang belanja, serta tombol "Kembali / Batal" di setiap halaman modal formulir.\cell
\row
\trowd\trgaph80\trleft0 \clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx400\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx2000\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx4900\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx5800\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx8900
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 H4\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Consistency & Standards\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Tombol aksi menggunakan warna berbeda-beda di halaman yang berbeda: kadang biru, oranye, atau hijau untuk aksi yang sama (simpan/ajukan).\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 2 \u8212? Minor\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Standarisasi warna tombol: Oranye (#ea580c) untuk aksi utama/pengajuan, Abu-abu untuk batal/kembali, Merah (#ef4444) untuk hapus/peringatan.\cell
\row
\trowd\trgaph80\trleft0 \clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx400\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx2000\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx4900\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx5800\clbrdrt\brdrs\brdrw8\clbrdrl\brdrs\brdrw8\clbrdrb\brdrs\brdrw8\clbrdrr\brdrs\brdrw8\cellx8900
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 H5\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Error Prevention\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Mahasiswa dapat mengetikkan jumlah pinjam melebihi stok tersedia di rak fisik, sehingga memicu error pada database dan proses tidak bisa dilanjutkan.\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 4 \u8212? Catastrophe\cell
\pard\intbl\ql\sb60\sa60\sl276\slmult1\b0\f0\fs22\cf0 Menambahkan validasi frontend secara real-time. Tombol "Pinjam" otomatis nonaktif (disabled) jika stok alat bernilai 0 atau jumlah input melebihi stok.\cell
\row
\pard\ql\sb280\sa80\f0\fs24\cf0\sl360\slmult1\b 9. HASIL PENGUJIAN SYSTEM USABILITY SCALE (SUS)\par
\pard\ql\sb0\sa120\brdrb\brdrs\brdrw6\brdrcf0 \par
\pard\qj\sb0\sa120\f0\fs24\cf0\sl360\slmult1\b0 Pengujian usability empiris dilakukan menggunakan instrumen System Usability Scale (SUS) standar dengan skala 10 pertanyaan, melibatkan 10 responden aktif dari kalangan mahasiswa dan penjaga laboratorium Teknik Elektro USK.\par
\pard\sb0\sa80\par
